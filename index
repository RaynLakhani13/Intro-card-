<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Velvet Ribbon Pictures - Title Card</title>
    <style>
        /* Reset and Layout */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body, html {
            width: 100%;
            height: 100%;
            background-color: #111;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            font-family: 'Courier New', Courier, monospace;
        }

        /* 16:9 Landscape Container */
        #canvas-container {
            position: relative;
            width: 100vw;
            height: 56.25vw; /* 16:9 Aspect Ratio */
            max-height: 100vh;
            max-width: 177.78vh; /* 16:9 Aspect Ratio */
            background: #1a1a1a;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
        }

        /* Stop-Motion Paper Texture Overlay */
        #canvas-container::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.08;
            pointer-events: none;
            z-index: 10;
            animation: noise 0.3s steps(4) infinite;
        }

        @keyframes noise {
            0% { transform: translate(0,0); }
            10% { transform: translate(-1%, -1%); }
            20% { transform: translate(1%, 2%); }
            30% { transform: translate(-2%, -2%); }
            40% { transform: translate(1%, 3%); }
            50% { transform: translate(-1%, 1%); }
            60% { transform: translate(2%, -1%); }
            70% { transform: translate(-2%, 1%); }
            80% { transform: translate(1%, -2%); }
            90% { transform: translate(-1%, 3%); }
            100% { transform: translate(0, 0); }
        }

        /* --- SCENE 1: THE DVD SHELF --- */
        .scene-shelf {
            position: absolute;
            inset: 0;
            background: #2b221a;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            padding-bottom: 10%;
            transition: opacity 0.2s steps(1);
        }

        /* Physical Wooden Shelf Graphic */
        .shelf-board {
            position: absolute;
            bottom: 8%;
            width: 90%;
            height: 4%;
            background: #140e0a;
            border: 2px solid #000;
            box-shadow: 0 10px 0 rgba(0,0,0,0.4);
        }

        .dvd-row {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            gap: 4px;
            width: 80%;
            height: 60%;
            z-index: 2;
            transform-origin: bottom center;
        }

        /* Stylized Stop-motion Cutout DVDs */
        .dvd {
            width: 6%;
            height: 85%;
            background: #444;
            border: 3px solid #fff;
            outline: 2px solid #000;
            transform: rotate(calc(var(--r) * 1deg));
            position: relative;
        }
        .dvd::before {
            content: '';
            position: absolute;
            top: 10%; left: 10%; right: 10%; bottom: 10%;
            background: var(--bg);
            border: 1px solid #000;
        }

        /* Target DVD to grab */
        .target-dvd {
            --bg: #7a1f1d !important;
            height: 90%;
            z-index: 5;
        }

        /* The Hand Cutout */
        .hand-cutout {
            position: absolute;
            right: -20%;
            bottom: -10%;
            width: 35%;
            height: 50%;
            background: #e0c097;
            border: 4px solid #fff;
            outline: 3px solid #000;
            box-shadow: 10px 10px 0 rgba(0,0,0,0.3);
            z-index: 6;
            transform: rotate(-20deg);
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            font-size: 1.5vw;
            /* Halftone-like texture pass */
            background-image: radial-gradient(rgba(0,0,0,0.15) 15%, transparent 16%);
            background-size: 6px 6px;
        }

        /* --- ANIMATION TIMINGS (SCENE 1) --- */
        .animate .hand-cutout {
            animation: grabSequence 1.5s steps(6) forwards;
        }
        .animate .target-dvd {
            animation: dvdSequence 1.5s steps(6) forwards;
        }
        .animate .scene-shelf {
            animation: fadeOutScene 1.5s steps(1) forwards;
        }

        @keyframes grabSequence {
            0% { transform: translate(0, 0) rotate(-20deg); }
            30% { transform: translate(-110%, -40%) rotate(-10deg); } /* Reaches DVD */
            50% { transform: translate(-110%, -40%) rotate(-5deg); }  /* Grabs */
            70% { transform: translate(-70%, 20%) rotate(-15deg); }   /* Pulls back down */
            100% { transform: translate(0%, 100%) rotate(0deg); }     /* Out of frame */
        }

        @keyframes dvdSequence {
            0% { transform: rotate(-2deg); }
            30% { transform: rotate(-2deg); }
            50% { transform: translate(-30%, -30%) rotate(15deg); } /* Hand lifts it */
            70% { transform: translate(40%, 150%) rotate(45deg); }  /* Pulled away */
            100% { transform: translate(40%, 150%) rotate(45deg); opacity: 0; }
        }

        @keyframes fadeOutScene {
            0%, 99% { opacity: 1; pointer-events: auto; }
            100% { opacity: 0; pointer-events: none; }
        }


        /* --- SCENE 2: THE HOLLYWOOD THEATER TRANSFORMATION --- */
        .scene-theater {
            position: absolute;
            inset: 0;
            background: #0a0505;
            opacity: 0;
            display: flex;
            justify-content: center;
            align-items: flex-end;
            z-index: 1;
        }

        /* Massive Theater Curtains */
        .curtain {
            position: absolute;
            top: 0;
            width: 51%;
            height: 100%;
            background: #540e10;
            background-image: linear-gradient(90deg, #3d0708 20%, #6e1619 50%, #3d0708 80%);
            background-size: 8% 100%;
            border: 3px solid #000;
            z-index: 3;
        }
        .curtain.left { left: 0; transform-origin: left center; }
        .curtain.right { right: 0; transform-origin: right center; }

        /* Stage Lights / Footlights */
        .stage-floor {
            width: 100%;
            height: 15%;
            background: #111;
            border-top: 4px solid #fff;
            outline: 2px solid #000;
            z-index: 4;
            display: flex;
            justify-content: space-around;
            padding: 0 10%;
        }
        .footlight {
            width: 4%;
            height: 30%;
            background: #ffeb99;
            border: 2px solid #000;
            border-radius: 50% 50% 0 0;
            box-shadow: 0 0 20px #ffeb99;
            opacity: 0;
        }

        /* --- ANIMATION TIMINGS (SCENE 2) --- */
        .animate .scene-theater {
            animation: fadeInScene 0.1s steps(1) 1.5s forwards;
        }
        .animate .curtain.left {
            animation: openCurtainLeft 1.2s steps(5) 1.6s forwards;
        }
        .animate .curtain.right {
            animation: openCurtainRight 1.2s steps(5) 1.6s forwards;
        }
        .animate .footlight {
            animation: turnOnLights 0.3s steps(2) 1.5s forwards;
        }

        @keyframes fadeInScene {
            to { opacity: 1; z-index: 3; }
        }
        @keyframes openCurtainLeft {
            to { transform: scaleX(0.15) skewY(2deg); }
        }
        @keyframes openCurtainRight {
            to { transform: scaleX(0.15) skewY(-2deg); }
        }
        @keyframes turnOnLights {
            to { opacity: 1; }
        }


        /* --- SCENE 3: THE LOGO CUT --- */
        .scene-logo {
            position: absolute;
            inset: 0;
            background: #83000d; /* Velvet Crimson Base */
            opacity: 0;
            z-index: 1;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .animate .scene-logo {
            animation: finalCut 0.1s steps(1) 2.6s forwards;
        }

        @keyframes finalCut {
            to { opacity: 1; z-index: 5; }
        }

        /* Recreating the Brand Aesthetic with pure CSS HTML Collage */
        .logo-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        /* Half-tone Styled Camera Outlines (Stickers) */
        .camera-sticker {
            position: absolute;
            background: #ccc;
            border: 4px solid #fff;
            outline: 2px solid #000;
            background-image: radial-gradient(#000 20%, transparent 25%);
            background-size: 4px 4px; /* Halftone effect */
            opacity: 0.85;
            box-shadow: 5px 5px 0 rgba(0,0,0,0.3);
        }

        /* Positioning the 4 camera corners from your branding */
        .cam-top-left {
            width: 25%; height: 30%;
            top: 5%; left: 5%;
            transform: rotate(-15deg);
        }
        .cam-top-right {
            width: 22%; height: 35%;
            top: -5%; right: 5%;
            transform: rotate(20deg);
        }
        .cam-bottom-left {
            width: 24%; height: 32%;
            bottom: -5%; left: 5%;
            transform: rotate(10deg);
        }
        .cam-bottom-right {
            width: 25%; height: 38%;
            bottom: -5%; right: 5%;
            transform: rotate(-5deg);
        }

        /* Central Typography Match */
        .brand-text {
            text-align: center;
            color: #fff;
            z-index: 6;
            text-shadow: 3px 3px 0 #000;
        }

        .brand-text h1 {
            font-family: 'Georgia', serif;
            font-size: 7vw;
            font-weight: 900;
            line-height: 0.85;
            letter-spacing: -2px;
            text-transform: lowercase;
            margin-bottom: 2%;
            transform: rotate(-3deg);
        }

        .brand-text h1 span {
            display: block;
            font-size: 9vw;
            text-transform: capitalize;
            padding-left: 2vw;
            transform: rotate(5deg);
        }

        .brand-text p {
            font-family: 'Arial', sans-serif;
            font-size: 1.8vw;
            letter-spacing: 0.6vw;
            text-transform: uppercase;
            margin-top: 5%;
            opacity: 0.9;
        }

        /* Replay prompt overlay */
        .prompt {
            position: absolute;
            bottom: 2%;
            left: 2%;
            color: rgba(255,255,255,0.3);
            font-size: 1vw;
            z-index: 100;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div id="canvas-container" class="animate">
        <div class="prompt">Click anywhere to replay</div>

        <div class="scene-shelf">
            <div class="dvd-row">
                <div class="dvd" style="--bg: #2a3d4a; --r: -3;"></div>
                <div class="dvd" style="--bg: #556b2f; --r: 1;"></div>
                <div class="dvd" style="--bg: #c7a75c; --r: -1;"></div>
                <div class="dvd target-dvd"></div> <div class="dvd" style="--bg: #4a2a43; --r: 2;"></div>
                <div class="dvd" style="--bg: #333333; --r: -2;"></div>
            </div>
            <div class="shelf-board"></div>
            <div class="hand-cutout">HAND</div>
        </div>

        <div class="scene-theater">
            <div class="curtain left"></div>
            <div class="curtain right"></div>
            <div class="stage-floor">
                <div class="footlight"></div>
                <div class="footlight"></div>
                <div class="footlight"></div>
                <div class="footlight"></div>
                <div class="footlight"></div>
            </div>
        </div>

        <div class="scene-logo">
            <div class="logo-wrapper">
                <div class="camera-sticker cam-top-left"></div>
                <div class="camera-sticker cam-top-right"></div>
                <div class="camera-sticker cam-bottom-left"></div>
                <div class="camera-sticker cam-bottom-right"></div>

                <div class="brand-text">
                    <h1>velvet<br><span>Ribbon</span></h1>
                    <p>Pictures</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Simple script to allow clicking anywhere to loop / test the animation easily
        const container = document.getElementById('canvas-container');
        
        document.body.addEventListener('click', () => {
            container.classList.remove('animate');
            void container.offsetWidth; // Trigger DOM reflow to reset CSS animations
            container.classList.add('animate');
        });
    </script>
</body>
</html>
